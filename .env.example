PORT=8080

# WhatsApp Cloud API Configuration
# Get these from Meta Developer Portal -> WhatsApp -> Configuration
VERIFY_TOKEN=your_verify_token_here             # Custom token you create for webhook verification
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id   # Your WhatsApp Business Account Phone Number ID
WHATSAPP_ACCESS_TOKEN=your_access_token         # Permanent access token from Meta
WHATSAPP_APP_SECRET=your_app_secret            # WhatsApp App Secret for webhook validation

# Supabase Configuration
# Get these from Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co   # Your Supabase project URL
SUPABASE_KEY=your_service_role_key              # Use service_role key for backend access
SESSIONS_DATABASE_URL=postgresql://...           # Full PostgreSQL connection string

# Google Cloud Configuration
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_PROJECT_ID=your-project-id               # Your Google Cloud Project ID
GOOGLE_API_KEY=your-api-key                     # API Key with Gemini API access